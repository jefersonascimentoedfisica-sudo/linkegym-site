# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Hardening: generated archives, local data, credentials, and data-mutating scripts
*.zip
*.dump
*.sql.gz
*.db
*.db.json
*.sqlite
*.sqlite3
.mcp.json
*service-account*.json
*service_role*.json
*service-role*.json
supabase/.branches/
supabase/.temp/
scripts/add-test-data.mjs
scripts/create-*-table.mjs
scripts/seed-*.mjs
